# Copy this file to .env and fill in values before running docker compose up

# MariaDB root password (used by OSCAR to connect to the database)
MYSQL_ROOT_PASSWORD=change_me_before_use

# MariaDB oscar user password
MYSQL_PASSWORD=oscar_change_me

# Port OSCAR is accessible on the host (default: 9090)
# Access at http://localhost:9090/oscar/
OSCAR_PORT=9090
